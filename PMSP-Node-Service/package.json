{
    "name": "pmsp-nfse-bridge",
    "version": "1.0.0",
    "description": "Bridge para emissão de NFSe da Prefeitura de São Paulo em Node.js",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "ts-node src/index.ts",
        "build": "tsc && copyfiles -u 1 \"src/wsdl/**/*\" dist/wsdl"
    },
    "dependencies": {
        "axios": "^1.13.6",
        "cors": "^2.8.6",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "fast-xml-parser": "^5.4.2",
        "node-forge": "^1.3.1",
        "soap": "^1.0.0",
        "winston": "^3.13.0",
        "xml-crypto": "^6.0.0",
        "xmlbuilder2": "^3.1.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.21",
        "@types/node": "^20.12.7",
        "@types/node-forge": "^1.3.11",
        "copyfiles": "^2.4.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.5"
    }
}
